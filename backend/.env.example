# FinGuide Backend — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/finGuide?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_hex_secret

# ─── Google Gemini ────────────────────────────────────────────────────────────
# Get this from: https://aistudio.google.com/apikey
# Key format for Gemini API is typically: AIzaSy...
GEMINI_API_KEY=your_gemini_api_key_here

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Dev frontend origin (localhost is always allowed by default, but set this
# if you run the frontend on a different port)
FRONTEND_URL=http://localhost:5173

# Production frontend URL — set this on your Render/Railway/EC2 backend env
PRODUCTION_FRONTEND_URL=https://finguide-frontend.onrender.com

# Legacy — still supported for backwards compatibility
# CLIENT_URL=https://finguide-frontend.onrender.com
