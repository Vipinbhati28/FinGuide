# App
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/finguide?retryWrites=true&w=majority

# Auth  (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=<64-byte-hex-secret>

# CORS
FRONTEND_URL=http://localhost:5173
PRODUCTION_FRONTEND_URL=https://your-frontend.onrender.com
CLIENT_URL=https://your-frontend.onrender.com

# AI — OpenRouter  (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Primary model — change to any OpenRouter-compatible model ID
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324
